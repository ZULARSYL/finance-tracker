<style>
.budget-card{
    background:#fff;
    border-radius:24px;
    padding:24px;
    box-shadow:0 4px 20px rgba(0,0,0,.05);
}

.btn-budget{
    background: var(--primary);
    color: white;
}

.btn-budget:hover{
    background:#128D24;
    color:white;
}

.progress{
    height:12px;
}

.progress-bar{
    border-radius:50px;
}

.form-control:focus{
    border-color: var(--primary);
    box-shadow: 0 0 0 .25rem rgba(10,92,21,.15);
}
</style>
<div class="container-fluid py-4">
    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-4">

        <div>
            <h2 class="fw-bold mb-1">Budgeting</h2>
            <p class="text-muted mb-0">
                Budget otomatis dihitung berdasarkan total pemasukan bulan ini untuk <%= currentMonthLabel %>.
            </p>
        </div>

        <button class="btn btn-budget"
                data-bs-toggle="modal"
                data-bs-target="#budgetModal">
            <i class="bi bi-sliders me-2"></i>
            Atur Rasio Budget
        </button>

    </div>

    <!-- SUMMARY -->
    <div class="row g-4 mb-4">

        <!-- TOTAL INCOME -->
        <div class="col-lg-3 col-md-6">
            <div class="budget-card">

                <div class="budget-icon bg-success-subtle text-success">
                    <i class="bi bi-cash-stack"></i>
                </div>

                <p class="text-muted mb-2">Total Pemasukan</p>

                <h4 class="fw-bold text-success">
                    Rp <%= totalIncome.toLocaleString('id-ID') %>
                </h4>

                <small class="text-muted">
                    <%= transactions.filter(t => t.jenis === 'Pemasukan').length %> transaksi pemasukan bulan ini
                </small>

            </div>
        </div>

        <!-- TOTAL BUDGET -->
        <div class="col-lg-3 col-md-6">
            <div class="budget-card">

                <div class="budget-icon bg-primary-subtle text-primary">
                    <i class="bi bi-wallet2"></i>
                </div>

                <p class="text-muted mb-2">
                    Budget Otomatis
                </p>

                <h4 class="fw-bold">
                    Rp <%= totalBudget.toLocaleString('id-ID') %>
                </h4>

                <small class="text-muted">
                    Menggunakan rasio <%= ratios.primer %>:<%= ratios.sekunder %>:<%= ratios.tabungan %>
                </small>

            </div>
        </div>

        <!-- USED -->
        <div class="col-lg-3 col-md-6">
            <div class="budget-card">

                <div class="budget-icon bg-warning-subtle text-warning">
                    <i class="bi bi-bar-chart-line"></i>
                </div>

                <p class="text-muted mb-2">
                    Sudah Digunakan
                </p>

                <h4 class="fw-bold">
                    Rp <%= usedTotal.toLocaleString('id-ID') %>
                </h4>

                <small class="text-muted">
                    <%= usagePercent.toFixed(1) %>% dari total budget
                </small>

            </div>
        </div>

        <!-- REMAINING -->
        <div class="col-lg-3 col-md-6">
            <div class="budget-card">

                <div class="budget-icon bg-success-subtle text-success">
                    <i class="bi bi-piggy-bank"></i>
                </div>

                <p class="text-muted mb-2">
                    Sisa Budget
                </p>

                <h4 class="fw-bold text-success">
                    Rp <%= remaining.toLocaleString('id-ID') %>
                </h4>

                <small class="text-muted">
                    Masih tersedia bulan ini
                </small>

            </div>
        </div>

    </div>

    <!-- DISTRIBUTION -->
    <div class="budget-card mb-4">

        <h5 class="fw-bold mb-4">
            Distribusi Otomatis Budget
        </h5>

        <div class="row text-center">

            <div class="col-md-4">
                <h1 class="fw-bold text-success"><%= ratios.primer %>%</h1>
                <p class="mb-1">Primer</p>
                <small class="text-muted">
                    Rp <%= allocation.primer.toLocaleString('id-ID') %>
                </small>
            </div>

            <div class="col-md-4">
                <h1 class="fw-bold text-warning"><%= ratios.sekunder %>%</h1>
                <p class="mb-1">Sekunder</p>
                <small class="text-muted">
                    Rp <%= allocation.sekunder.toLocaleString('id-ID') %>
                </small>
            </div>

            <div class="col-md-4">
                <h1 class="fw-bold text-primary"><%= ratios.tabungan %>%</h1>
                <p class="mb-1">Tabungan</p>
                <small class="text-muted">
                    Rp <%= allocation.tabungan.toLocaleString('id-ID') %>
                </small>
            </div>

        </div>

    </div>

    <!-- ALLOCATION -->
    <div class="row g-4 mb-4">

        <div class="col-lg-8">

            <div class="budget-card">

                <h5 class="fw-bold mb-4">
                    Progress Penggunaan Budget
                </h5>

                <!-- PRIMER -->
                <div class="mb-4">

                    <div class="d-flex justify-content-between mb-2">
                        <span class="fw-semibold">
                            Primer
                        </span>

                        <span>
                            Rp <%= used.primer.toLocaleString('id-ID') %> / Rp <%= allocation.primer.toLocaleString('id-ID') %>
                        </span>
                    </div>

                    <div class="progress mb-2">
                        <div class="progress-bar budget-primary"
                             data-width="<%= progressPrimerPercent.toFixed(0) %>">
                        </div>
                    </div>

                    <small class="text-muted">
                        Makan, Transportasi, Komunikasi, Pendidikan
                    </small>

                </div>

                <!-- SEKUNDER -->
                <div class="mb-4">

                    <div class="d-flex justify-content-between mb-2">
                        <span class="fw-semibold">
                            Sekunder
                        </span>

                        <span>
                            Rp <%= used.sekunder.toLocaleString('id-ID') %> / Rp <%= allocation.sekunder.toLocaleString('id-ID') %>
                        </span>
                    </div>

                    <div class="progress mb-2">
                        <div class="progress-bar bg-warning"
                             data-width="<%= progressSekunderPercent.toFixed(0) %>">
                        </div>
                    </div>

                    <small class="text-muted">
                        Hiburan, Olahraga, Belanja
                    </small>

                </div>

                <!-- TABUNGAN -->
                <div>

                    <div class="d-flex justify-content-between mb-2">
                        <span class="fw-semibold">
                            Tabungan
                        </span>

                        <span>
                            Rp <%= used.tabungan.toLocaleString('id-ID') %> / Rp <%= allocation.tabungan.toLocaleString('id-ID') %>
                        </span>
                    </div>

                    <div class="progress mb-2">
                        <div class="progress-bar bg-info"
                             data-width="<%= progressTabunganPercent.toFixed(0) %>">
                        </div>
                    </div>

                    <small class="text-muted">
                        Tabungan, Investasi, Dana Darurat
                    </small>

                </div>

            </div>

        </div>

        <!-- GOAL -->
        <div class="col-lg-4">

            <div class="budget-card h-100">

                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h5 class="fw-bold mb-0">
                        Goal Menabung
                    </h5>

                    <button class="btn btn-success rounded-circle" data-bs-toggle="modal" data-bs-target="#goalModal">
                        <i class="bi bi-plus"></i>
                    </button>
                </div>

                <h3 class="fw-bold">
                    <%= goalTitle %>
                </h3>

                <p class="text-muted">
                    Target Rp <%= goalTarget.toLocaleString('id-ID') %>
                </p>

                <div class="text-center my-4">

                    <h1 class="fw-bold text-success">
                        <%= goalPercent.toFixed(0) %>%
                    </h1>

                    <p class="text-muted">
                        Rp <%= goalCurrent.toLocaleString('id-ID') %> terkumpul
                    </p>

                </div>

                <div class="progress">
                    <div class="progress-bar budget-primary"
                         data-width="<%= goalPercent.toFixed(0) %>">
                    </div>
                </div>

            </div>

        </div>

    </div>

    <!-- RECOMMENDATION -->
    <div class="budget-card">

        <h5 class="fw-bold mb-4">
            Insight Budget
        </h5>

        <div class="row g-4">

            <div class="col-md-4">

                <div class="recommend-box">

                    <i class="bi bi-check-circle-fill text-success fs-2"></i>

                    <h6 class="fw-bold mt-3">
                        Pengeluaran Aman
                    </h6>

                    <p class="text-muted mb-0">
                        <%= insight.primer %>
                    </p>

                </div>

            </div>

            <div class="col-md-4">

                <div class="recommend-box">

                    <i class="bi bi-exclamation-circle-fill text-warning fs-2"></i>

                    <h6 class="fw-bold mt-3">
                        Sekunder Tinggi
                    </h6>

                    <p class="text-muted mb-0">
                        <%= insight.sekunder %>
                    </p>

                </div>

            </div>

            <div class="col-md-4">

                <div class="recommend-box">

                    <i class="bi bi-piggy-bank-fill text-success fs-2"></i>

                    <h6 class="fw-bold mt-3">
                        Menabung Baik
                    </h6>

                    <p class="text-muted mb-0">
                        <%= insight.tabungan %>
                    </p>

                </div>

            </div>

        </div>

    </div>

</div>

<script>
document.addEventListener('DOMContentLoaded', () => {
    document.querySelectorAll('.progress-bar[data-width]').forEach((element) => {
        const width = element.getAttribute('data-width');
        if (width !== null) {
            element.style.width = `${width}%`;
        }
    });
});
</script>

<%- include('partials/modal.ejs') %>
