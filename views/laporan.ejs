<style>
.report-card{
    background:#fff;
    border-radius:24px;
    padding:24px;
    box-shadow:0 4px 20px rgba(0,0,0,.05);
}

.report-icon{
    width:60px;
    height:60px;
    border-radius:18px;
    display:flex;
    align-items:center;
    justify-content:center;
    font-size:24px;
    margin-bottom:15px;
}

.income-icon{
    background:#EAF8EC;
    color:#0A5C15;
}

.expense-icon{
    background:#FDECEC;
    color:#dc3545;
}

.saving-icon{
    background:#EEF4FF;
    color:#0d6efd;
}

.budget-icon{
    background:#FFF6DD;
    color:#ffc107;
}

.btn-report{
    background:#0A5C15;
    color:white;
    border:none;
    border-radius:12px;
}

.btn-report:hover{
    background:#128D24;
    color:white;
}

.transaction-item{
    display:flex;
    justify-content:space-between;
    align-items:center;
    padding:18px 0;
    border-bottom:1px solid #f1f1f1;
}

.transaction-item:last-child{
    border-bottom:none;
}

.progress{
    height:12px;
    border-radius:50px;
    background:#eef2f3;
    overflow:hidden;
}

.progress-bar{
    height:100%;
    border-radius:50px;
    transition: width 0.3s ease;
}

.budget-section-title{
    display:flex;
    align-items:center;
    gap:10px;
    margin-bottom:20px;
}

.budget-item{
    margin-bottom:25px;
}

.budget-label{
    display:flex;
    justify-content:space-between;
    align-items:center;
    margin-bottom:8px;
    font-size:14px;
    font-weight:500;
}

.budget-percentage{
    display:inline-block;
    background:#f0f0f0;
    padding:2px 8px;
    border-radius:4px;
    font-size:12px;
    color:#666;
}
</style>
<div class="container-fluid py-4">

    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">

        <div>
            <h2 class="fw-bold mb-1">Laporan Keuangan</h2>
            <p class="text-muted mb-0">
                Ringkasan keuangan berdasarkan periode yang dipilih.
            </p>
        </div>

        <div class="d-flex gap-2">

            <input type="month" class="form-control">

            <button class="btn btn-outline-success">
                <i class="bi bi-search"></i>
            </button>

            <button class="btn btn-outline-danger">
                <i class="bi bi-file-earmark-pdf me-2"></i>
                Export PDF
            </button>

            <button class="btn btn-report" onclick="window.print()">
                <i class="bi bi-printer me-2"></i>
                Print
            </button>

        </div>

    </div>

    <!-- SUMMARY -->
    <div class="row g-4 mb-4">

        <div class="col-lg-3 col-md-6">
            <div class="report-card">
                <div class="report-icon income-icon">
                    <i class="bi bi-arrow-down-circle"></i>
                </div>

                <p class="text-muted mb-1">Pemasukan</p>

                <h4 class="fw-bold text-success">
                    Rp <%= totalIncome.toLocaleString('id-ID') %>
                </h4>

                <small class="text-muted">
                    <%= totalIncomeTransactions %> transaksi
                </small>
            </div>
        </div>

        <div class="col-lg-3 col-md-6">
            <div class="report-card">
                <div class="report-icon expense-icon">
                    <i class="bi bi-arrow-up-circle"></i>
                </div>

                <p class="text-muted mb-1">Pengeluaran</p>

                <h4 class="fw-bold text-danger">
                    Rp <%= totalExpense.toLocaleString('id-ID') %>
                </h4>

                <small class="text-muted">
                    <%= totalExpenseTransactions %> transaksi
                </small>
            </div>
        </div>

        <div class="col-lg-3 col-md-6">
            <div class="report-card">
                <div class="report-icon saving-icon">
                    <i class="bi bi-piggy-bank"></i>
                </div>

                <p class="text-muted mb-1">Tabungan</p>

                <h4 class="fw-bold text-primary">
                    Rp <%= TabunganReport.toLocaleString('id-ID')%>
                </h4>

                <small class="text-muted">
                    <%= ratioTabungan %>% dari pemasukan
                </small>
            </div>
        </div>

        <div class="col-lg-3 col-md-6">
            <div class="report-card">
                <div class="report-icon budget-icon">
                    <i class="bi bi-bar-chart"></i>
                </div>

                <p class="text-muted mb-1">Status Budget</p>

                <h4 class="fw-bold <% if(progress_pengeluaran > 80) { %>text-danger<% } else if(progress_pengeluaran > 60) { %>text-warning<% } else { %>text-success<% } %>">
                    <% if(progress_pengeluaran > 80) { %>
                        Kritis
                    <% } else if(progress_pengeluaran > 60) { %>
                        Hati-hati
                    <% } else { %>
                        Aman
                    <% } %>
                </h4>

                <small class="text-muted">
                    <%= progress_pengeluaran.toFixed(1) %>% budget telah digunakan
                </small>
            </div>
        </div>

    </div>

    <!-- CHART -->
    <div class="report-card mb-4">

        <div class="d-flex justify-content-between align-items-center mb-4">
            <h5 class="fw-bold mb-0">
                Grafik Keuangan Bulanan
            </h5>
        </div>

        <canvas id="financeChart" height="90"></canvas>

    </div>

    <div class="row g-4">

        <!-- INCOME -->
        <div class="col-lg-6">

            <div class="report-card h-100">

                <div class="d-flex justify-content-between align-items-center mb-4">

                    <h5 class="fw-bold mb-0">
                        Laporan Pemasukan
                    </h5>

                    <span class="badge bg-success">
                        Rp <%= totalIncome.toLocaleString('id-ID') %>
                    </span>

                </div>
                <% IncomeTransactions.forEach(t => { %>
                <div class="transaction-item">
                    <div>
                        <h6 class="mb-1"><%= t.kategori %></h6>
                        <small class="text-muted"><%= new Date(t.tanggal).toLocaleDateString('id-ID', { 
                                        day: 'numeric',
                                        month: 'long',
                                        year: 'numeric'
                                    }) %>
                        </small>
                    </div>

                    <span class="text-success fw-bold">
                        + Rp <%= t.nominal.toLocaleString('id-ID') %>
                    </span>
                </div>
                <% }); %>
            </div>

        </div>

        <!-- EXPENSE -->
        <div class="col-lg-6">

            <div class="report-card h-100">

                <div class="d-flex justify-content-between align-items-center mb-4">

                    <h5 class="fw-bold mb-0">
                        Laporan Pengeluaran
                    </h5>

                    <span class="badge bg-danger">
                        Rp <%= totalExpense.toLocaleString('id-ID') %>
                    </span>

                </div>
                <% ExpenseTransactions.forEach(t => { %>
                <div class="transaction-item">
                    <div>
                        <h6 class="mb-1"><%= t.kategori %></h6>
                        <small class="text-muted"><%= new Date(t.tanggal).toLocaleDateString('id-ID', { 
                                        day: 'numeric',
                                        month: 'long',
                                        year: 'numeric'
                                    }); %>
                        </small>
                    </div>

                    <span class="text-danger fw-bold">
                        - Rp <%= t.nominal.toLocaleString('id-ID') %>
                    </span>
                </div>
                <% }); %>
            </div>
        </div>

    </div>

    <!-- BUDGET ANALYSIS -->
    <div class="report-card mt-4">

        <div class="budget-section-title">
            <i class="bi bi-pie-chart" style="font-size:24px; color:#0A5C15;"></i>
            <h5 class="fw-bold mb-0">
                Analisis Budget Anda
            </h5>
        </div>

        <!-- INCOME vs EXPENSE ANALYSIS -->
        <div class="budget-item mb-5 p-3 rounded" style="background:#f8f9fa;">
            <div class="budget-label">
                <span>
                    <i class="bi bi-graph-up text-success me-2"></i>
                    Perbandingan Pemasukan & Pengeluaran
                </span>
                <span class="budget-percentage">
                    <%= progress_pengeluaran.toFixed(1) %>%
                </span>
            </div>
            <small class="text-muted d-block mb-2">
                Rp <%= totalExpense.toLocaleString('id-ID') %> dari Rp <%= totalIncome.toLocaleString('id-ID') %>
            </small>
            <div class="progress" style="height:16px;">
                <div class="progress-bar bg-danger" style="width:<%= progress_pengeluaran %>%"></div>
            </div>
        </div>

        <!-- BUDGET ALLOCATION 50:30:20 -->
        <div style="margin-bottom:30px;">
            <h6 class="fw-bold mb-3">
                <i class="bi bi-percent"></i> Alokasi Budget <%= ratioPrimer %> : <%= ratioSekunder %> : <%= ratioTabungan %>
            </h6>

            <!-- Primer (50%) -->
            <div class="budget-item">
                <div class="budget-label">
                    <span>
                        <span class="badge bg-success"><%= ratioPrimer %>%</span>
                        Primer (Kebutuhan)
                    </span>
                    <span class="budget-percentage">
                        <%= progressPrimerPercent.toFixed(1) %>%
                    </span>
                </div>
                <small class="text-muted d-block mb-2">
                    Rp <%= used.primer.toLocaleString('id-ID') %> / Rp <%= allocation.primer.toLocaleString('id-ID') %>
                </small>
                <div class="progress">
                    <div class="progress-bar bg-success" style="width: <%= progressPrimerPercent || 0 %>%"></div>
                </div>
            </div>

            <!-- Sekunder (30%) -->
            <div class="budget-item">
                <div class="budget-label">
                    <span>
                        <span class="badge bg-warning"><%= ratioSekunder %>%</span>
                        Sekunder (Keinginan)
                    </span>
                    <span class="budget-percentage">
                        <%= progressSekunderPercent.toFixed(1) %>%
                    </span>
                </div>
                <small class="text-muted d-block mb-2">
                    Rp <%= used.sekunder.toLocaleString('id-ID') %> / Rp <%= allocation.sekunder.toLocaleString('id-ID') %>
                </small>
                <div class="progress">
                    <div class="progress-bar bg-warning" style="width: <%= progressSekunderPercent || 0 %>%"></div>
                </div>
            </div>

            <!-- Tabungan (20%) -->
            <div class="budget-item">
                <div class="budget-label">
                    <span>
                        <span class="badge bg-primary"><%= ratioTabungan %>%</span>
                        Tabungan & Investasi
                    </span>
                    <span class="budget-percentage">
                        <%= progressTabunganPercent.toFixed(1) %>%
                    </span>
                </div>
                <small class="text-muted d-block mb-2">
                    Rp <%= used.tabungan.toLocaleString('id-ID') %> / Rp <%= allocation.tabungan.toLocaleString('id-ID') %>
                </small>
                <div class="progress">
                    <div class="progress-bar bg-primary" style="width: <%= progressTabunganPercent || 0 %>%"></div>
                </div>
            </div>

        </div>

        <!-- STATUS & TIPS -->
        <div class="alert alert-info border-0 rounded" role="alert">
            <strong>
                <i class="bi bi-lightbulb me-2"></i>
                Saran untuk Anda:
            </strong>
            <ul class="mb-0 mt-2">
                <li><% if(progressPrimerPercent > 100) { %>
                    Pengeluaran Primer Anda melebihi budget yang dialokasikan. Pertimbangkan untuk mengurangi pengeluaran kebutuhan.
                <% } else { %>
                    Pengeluaran Primer Anda masih dalam batas wajar.
                <% } %></li>
                <li><% if(progressTabunganPercent < 20) { %>
                    Tabungan Anda masih kurang dari target 20%. Tingkatkan porsi tabungan Anda.
                <% } else { %>
                    Tabungan Anda sudah mencapai atau melampaui target 20%.
                <% } %></li>
            </ul>
        </div>

    </div>

</div>