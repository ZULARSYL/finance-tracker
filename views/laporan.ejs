<style>
.report-card{
    background:#fff;
    border-radius:24px;
    padding:24px;
    box-shadow:0 4px 20px rgba(0,0,0,.05);
}

.report-icon{
    width:60px;
    height:60px;
    border-radius:18px;
    display:flex;
    align-items:center;
    justify-content:center;
    font-size:24px;
    margin-bottom:15px;
}

.income-icon{
    background:#EAF8EC;
    color:#0A5C15;
}

.expense-icon{
    background:#FDECEC;
    color:#dc3545;
}

.saving-icon{
    background:#EEF4FF;
    color:#0d6efd;
}

.budget-icon{
    background:#FFF6DD;
    color:#ffc107;
}

.btn-report{
    background:#0A5C15;
    color:white;
    border:none;
    border-radius:12px;
}

.btn-report:hover{
    background:#128D24;
    color:white;
}

.transaction-item{
    display:flex;
    justify-content:space-between;
    align-items:center;
    padding:18px 0;
    border-bottom:1px solid #f1f1f1;
}

.transaction-item:last-child{
    border-bottom:none;
}

.progress{
    height:12px;
    border-radius:50px;
    background:#eef2f3;
}
</style>
<div class="container-fluid py-4">

    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">

        <div>
            <h2 class="fw-bold mb-1">Laporan Keuangan</h2>
            <p class="text-muted mb-0">
                Ringkasan keuangan berdasarkan periode yang dipilih.
            </p>
        </div>

        <div class="d-flex gap-2">

            <input type="month" class="form-control">

            <button class="btn btn-outline-success">
                <i class="bi bi-search"></i>
            </button>

            <button class="btn btn-outline-danger">
                <i class="bi bi-file-earmark-pdf me-2"></i>
                Export PDF
            </button>

            <button class="btn btn-report" onclick="window.print()">
                <i class="bi bi-printer me-2"></i>
                Print
            </button>

        </div>

    </div>

    <!-- SUMMARY -->
    <div class="row g-4 mb-4">

        <div class="col-lg-3 col-md-6">
            <div class="report-card">
                <div class="report-icon income-icon">
                    <i class="bi bi-arrow-down-circle"></i>
                </div>

                <p class="text-muted mb-1">Pemasukan</p>

                <h4 class="fw-bold text-success">
                    Rp <%= totalIncome.toLocaleString('id-ID') %>
                </h4>

                <small class="text-muted">
                    3 transaksi
                </small>
            </div>
        </div>

        <div class="col-lg-3 col-md-6">
            <div class="report-card">
                <div class="report-icon expense-icon">
                    <i class="bi bi-arrow-up-circle"></i>
                </div>

                <p class="text-muted mb-1">Pengeluaran</p>

                <h4 class="fw-bold text-danger">
                    Rp <%= totalExpense.toLocaleString('id-ID') %>
                </h4>

                <small class="text-muted">
                    24 transaksi
                </small>
            </div>
        </div>

        <div class="col-lg-3 col-md-6">
            <div class="report-card">
                <div class="report-icon saving-icon">
                    <i class="bi bi-piggy-bank"></i>
                </div>

                <p class="text-muted mb-1">Tabungan</p>

                <h4 class="fw-bold text-primary">
                    rp
                </h4>

                <small class="text-muted">
                    32.5% dari pemasukan
                </small>
            </div>
        </div>

        <div class="col-lg-3 col-md-6">
            <div class="report-card">
                <div class="report-icon budget-icon">
                    <i class="bi bi-bar-chart"></i>
                </div>

                <p class="text-muted mb-1">Status Budget</p>

                <h4 class="fw-bold text-success">
                    Aman
                </h4>

                <small class="text-muted">
                    67% budget telah digunakan
                </small>
            </div>
        </div>

    </div>

    <!-- CHART -->
    <div class="report-card mb-4">

        <div class="d-flex justify-content-between align-items-center mb-4">
            <h5 class="fw-bold mb-0">
                Grafik Keuangan Bulanan
            </h5>
        </div>

        <canvas id="financeChart" height="90"></canvas>

    </div>

    <div class="row g-4">

        <!-- INCOME -->
        <div class="col-lg-6">

            <div class="report-card h-100">

                <div class="d-flex justify-content-between align-items-center mb-4">

                    <h5 class="fw-bold mb-0">
                        Laporan Pemasukan
                    </h5>

                    <span class="badge bg-success">
                        Rp <%= totalIncome.toLocaleString('id-ID') %>
                    </span>

                </div>
                <% IncomeTransactions.forEach(t => { %>
                <div class="transaction-item">
                    <div>
                        <h6 class="mb-1"><%= t.kategori %></h6>
                        <small class="text-muted"><%= new Date(t.tanggal).toLocaleDateString('id-ID', { 
                                        day: 'numeric',
                                        month: 'long',
                                        year: 'numeric'
                                    }) %>
                        </small>
                    </div>

                    <span class="text-success fw-bold">
                        + Rp <%= t.nominal.toLocaleString('id-ID') %>
                    </span>
                </div>
                <% }); %>
            </div>

        </div>

        <!-- EXPENSE -->
        <div class="col-lg-6">

            <div class="report-card h-100">

                <div class="d-flex justify-content-between align-items-center mb-4">

                    <h5 class="fw-bold mb-0">
                        Laporan Pengeluaran
                    </h5>

                    <span class="badge bg-danger">
                        Rp <%= totalExpense.toLocaleString('id-ID') %>
                    </span>

                </div>
                <% ExpenseTransactions.forEach(t => { %>
                <div class="transaction-item">
                    <div>
                        <h6 class="mb-1"><%= t.kategori %></h6>
                        <small class="text-muted"><%= new Date(t.tanggal).toLocaleDateString('id-ID', { 
                                        day: 'numeric',
                                        month: 'long',
                                        year: 'numeric'
                                    }); %>
                        </small>
                    </div>

                    <span class="text-danger fw-bold">
                        - Rp <%= t.nominal.toLocaleString('id-ID') %>
                    </span>
                </div>
                <% }); %>
            </div>
        </div>

    </div>

    <!-- BUDGET ANALYSIS -->
    <div class="report-card mt-4">

        <h5 class="fw-bold mb-4">
            Analisis Budget 50 : 30 : 20
        </h5>

        <!-- Primer -->
        <div class="mb-4">

            <div class="d-flex justify-content-between mb-2">
                <span>Primer</span>
                <span>Rp 1.300.000 / Rp 2.000.000</span>
            </div>

            <div class="progress">
                <div class="progress-bar bg-success" style="width:65%"></div>
            </div>

        </div>

        <!-- Sekunder -->
        <div class="mb-4">

            <div class="d-flex justify-content-between mb-2">
                <span>Sekunder</span>
                <span>Rp 1.000.000 / Rp 1.200.000</span>
            </div>

            <div class="progress">
                <div class="progress-bar bg-warning" style="width:83%"></div>
            </div>

        </div>

        <!-- Tabungan -->
        <div>

            <div class="d-flex justify-content-between mb-2">
                <span>Tabungan</span>
                <span>Rp 400.000 / Rp 800.000</span>
            </div>

            <div class="progress">
                <div class="progress-bar bg-primary" style="width:50%"></div>
            </div>

        </div>

    </div>

</div>