<style>
.report-card{
    background:#fff;
    border-radius:24px;
    padding:24px;
    box-shadow:0 4px 20px rgba(0,0,0,.05);
}

.report-icon{
    width:60px;
    height:60px;
    border-radius:18px;
    display:flex;
    align-items:center;
    justify-content:center;
    font-size:24px;
    margin-bottom:15px;
}

.income-icon{
    background:#EAF8EC;
    color:#0A5C15;
}

.expense-icon{
    background:#FDECEC;
    color:#dc3545;
}

.saving-icon{
    background:#EEF4FF;
    color:#0d6efd;
}

.budget-icon{
    background:#FFF6DD;
    color:#ffc107;
}

.btn-report{
    background:#0A5C15;
    color:white;
    border:none;
    border-radius:12px;
}

.btn-report:hover{
    background:#128D24;
    color:white;
}

.transaction-item{
    display:flex;
    justify-content:space-between;
    align-items:center;
    padding:18px 0;
    border-bottom:1px solid #f1f1f1;
}

.transaction-item:last-child{
    border-bottom:none;
}

.progress{
    height:12px;
    border-radius:50px;
    background:#eef2f3;
    overflow:hidden;
}

.progress-bar{
    height:100%;
    border-radius:50px;
    transition: width 0.3s ease;
}

.budget-section-title{
    display:flex;
    align-items:center;
    gap:10px;
    margin-bottom:20px;
}

.budget-item{
    margin-bottom:25px;
}

.budget-label{
    display:flex;
    justify-content:space-between;
    align-items:center;
    margin-bottom:8px;
    font-size:14px;
    font-weight:500;
}

.budget-percentage{
    display:inline-block;
    background:#f0f0f0;
    padding:2px 8px;
    border-radius:4px;
    font-size:12px;
    color:#666;
}

#financeChart {
    max-height: 400px;
    width: 100% !important;
}

.chart-container {
    position: relative;
    width: 100%;
    background: #fff;
    border-radius: 24px;
    padding: 28px;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.05);
}

.chart-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 24px;
}

.chart-header h5 {
    color: #1a1a1a;
    font-size: 18px;
    font-weight: 600;
    margin: 0;
    display: flex;
    align-items: center;
    gap: 10px;
    color: #0A5C15;
}

.chart-header p {
    color: #888;
    font-size: 13px;
    margin: 6px 0 0 32px;
}

.chart-header .view-details {
    background: #f0f0f0;
    color: #0A5C15;
    border: 1px solid #e0e0e0;
    padding: 8px 16px;
    border-radius: 8px;
    font-size: 12px;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.3s ease;
}

.chart-header .view-details:hover {
    background: #0A5C15;
    color: #fff;
    border-color: #0A5C15;
}
</style>
<div class="container-fluid py-4">

    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">

        <div>
            <h2 class="fw-bold mb-1">Laporan Keuangan</h2>
            <p class="text-muted mb-0">
                Ringkasan keuangan berdasarkan periode yang dipilih.
            </p>
        </div>

        <div class="d-flex gap-2">
            <form class="row g-3" method="GET" action="/laporan">
                <div class="col-md-6">
                    <input
                        type="month"
                        name="month"
                        class="form-control"
                        value="<%= filters && filters.month ? filters.month : '' %>">
                </div>
                <div class="col-md-3 d-flex gap-2">
                    <button class="btn btn-outline-success w-100" type="submit">
                        Filter
                    </button>
                    <a href="/laporan" class="btn btn-outline-secondary w-100">
                        Reset
                    </a>
                </div>
            </form>

            <button class="btn btn-outline-danger">
                <a href="/laporan/export?month=<%= filters.month %>" class="text-decoration-none text-danger">
                    <i class="bi bi-file-earmark-pdf me-2"></i>
                    Export PDF
                </a>
            </button>
        </div>

    </div>

    <!-- SUMMARY -->
    <div class="row g-4 mb-4">

        <div class="col-lg-3 col-md-6">
            <div class="report-card">
                <div class="report-icon income-icon">
                    <i class="bi bi-arrow-down-circle"></i>
                </div>

                <p class="text-muted mb-1">Pemasukan</p>

                <h4 class="fw-bold text-success">
                    Rp <%= totalIncome.toLocaleString('id-ID') %>
                </h4>

                <small class="text-muted">
                    <%= totalIncomeTransactions %> transaksi
                </small>
            </div>
        </div>

        <div class="col-lg-3 col-md-6">
            <div class="report-card">
                <div class="report-icon expense-icon">
                    <i class="bi bi-arrow-up-circle"></i>
                </div>

                <p class="text-muted mb-1">Pengeluaran</p>

                <h4 class="fw-bold text-danger">
                    Rp <%= totalExpense.toLocaleString('id-ID') %>
                </h4>

                <small class="text-muted">
                    <%= totalExpenseTransactions %> transaksi
                </small>
            </div>
        </div>

        <div class="col-lg-3 col-md-6">
            <div class="report-card">
                <div class="report-icon saving-icon">
                    <i class="bi bi-piggy-bank"></i>
                </div>

                <p class="text-muted mb-1">Tabungan</p>

                <h4 class="fw-bold text-primary">
                    Rp <%= TabunganReport.toLocaleString('id-ID')%>
                </h4>

                <small class="text-muted">
                    <%= ratioTabungan %>% dari pemasukan
                </small>
            </div>
        </div>

        <div class="col-lg-3 col-md-6">
            <div class="report-card">
                <div class="report-icon budget-icon">
                    <i class="bi bi-bar-chart"></i>
                </div>

                <p class="text-muted mb-1">Status Budget</p>

                <h4 class="fw-bold <% if(progress_pengeluaran > 80) { %>text-danger<% } else if(progress_pengeluaran > 60) { %>text-warning<% } else { %>text-success<% } %>">
                    <% if(progress_pengeluaran > 80) { %>
                        Kritis
                    <% } else if(progress_pengeluaran > 60) { %>
                        Hati-hati
                    <% } else { %>
                        Aman
                    <% } %>
                </h4>

                <small class="text-muted">
                    <%= progress_pengeluaran.toFixed(1) %>% budget telah digunakan
                </small>
            </div>
        </div>

    </div>

    <!-- CHART -->
    <div class="chart-container mb-4">

        <div class="chart-header">
            <div>
                <h5>
                    <i class="bi bi-graph-up"></i>
                    Keuangan Bulanan
                </h5>
                <p style="color: rgba(255, 255, 255, 0.6); font-size: 13px; margin: 4px 0 0 0; margin-left: 32px;">Perbandingan pemasukan dan pengeluaran per bulan.</p>
            </div>
        </div>

        <canvas id="financeChart" height="90"></canvas>

    </div>

    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const chartDataString = '<%- chartData %>';
            const chartData = JSON.parse(chartDataString);
            
            const ctx = document.getElementById('financeChart').getContext('2d');
            
            new Chart(ctx, {
                type: 'bar',
                data: {
                    labels: chartData.labels,
                    datasets: chartData.datasets.map((dataset, idx) => ({
                        ...dataset,
                        backgroundColor: idx === 0 
                            ? ['#0A5C15', '#0A5C15', '#0A5C15', '#0A5C15', '#0A5C15', '#0A5C15', '#0A5C15', '#0A5C15', '#128D24', '#128D24', '#128D24', '#128D24']
                            : ['#64b5e6', '#64b5e6', '#64b5e6', '#64b5e6', '#64b5e6', '#64b5e6', '#64b5e6', '#64b5e6', '#42a5f5', '#42a5f5', '#42a5f5', '#42a5f5']
                    }))
                },
                options: {
                    indexAxis: 'x',
                    responsive: true,
                    maintainAspectRatio: true,
                    interaction: {
                        intersect: false,
                        mode: 'index'
                    },
                    plugins: {
                        legend: {
                            display: true,
                            position: 'top',
                            labels: {
                                usePointStyle: true,
                                padding: 20,
                                font: {
                                    size: 12,
                                    weight: '500'
                                },
                                color: '#666',
                                pointStyle: 'rect'
                            }
                        },
                        tooltip: {
                            backgroundColor: 'rgba(0, 0, 0, 0.85)',
                            titleFont: { size: 12, weight: '600' },
                            bodyFont: { size: 11 },
                            padding: 12,
                            displayColors: true,
                            borderColor: 'rgba(255, 255, 255, 0.1)',
                            borderWidth: 1,
                            callbacks: {
                                label: function(context) {
                                    const value = context.parsed.y || 0;
                                    return context.dataset.label + ': Rp ' + value.toLocaleString('id-ID');
                                }
                            }
                        }
                    },
                    scales: {
                        y: {
                            beginAtZero: true,
                            grid: {
                                color: 'rgba(0, 0, 0, 0.05)',
                                drawBorder: false
                            },
                            ticks: {
                                font: { size: 11 },
                                color: '#999',
                                callback: function(value) {
                                    if (value >= 1000000) {
                                        return 'Rp ' + (value / 1000000).toFixed(0) + 'M';
                                    } else if (value >= 1000) {
                                        return 'Rp ' + (value / 1000).toFixed(0) + 'K';
                                    }
                                    return 'Rp ' + value;
                                }
                            }
                        },
                        x: {
                            grid: {
                                display: false,
                                drawBorder: false
                            },
                            ticks: {
                                font: { size: 11, weight: '500' },
                                color: '#666'
                            }
                        }
                    }
                }
            });
        });
    </script>

    <div class="row g-4">

        <!-- INCOME -->
        <div class="col-lg-6">

            <div class="report-card h-100">

                <div class="d-flex justify-content-between align-items-center mb-4">

                    <h5 class="fw-bold mb-0">
                        Laporan Pemasukan
                    </h5>

                    <span class="badge bg-success">
                        Rp <%= totalIncome.toLocaleString('id-ID') %>
                    </span>

                </div>
                <% IncomeTransactions.forEach(t => { %>
                <div class="transaction-item">
                    <div>
                        <h6 class="mb-1"><%= t.kategori %></h6>
                        <small class="text-muted"><%= new Date(t.tanggal).toLocaleDateString('id-ID', { 
                                        day: 'numeric',
                                        month: 'long',
                                        year: 'numeric'
                                    }) %>
                        </small>
                    </div>

                    <span class="text-success fw-bold">
                        + Rp <%= t.nominal.toLocaleString('id-ID') %>
                    </span>
                </div>
                <% }); %>
            </div>

        </div>

        <!-- EXPENSE -->
        <div class="col-lg-6">

            <div class="report-card h-100">

                <div class="d-flex justify-content-between align-items-center mb-4">

                    <h5 class="fw-bold mb-0">
                        Laporan Pengeluaran
                    </h5>

                    <span class="badge bg-danger">
                        Rp <%= totalExpense.toLocaleString('id-ID') %>
                    </span>

                </div>
                <% ExpenseTransactions.forEach(t => { %>
                <div class="transaction-item">
                    <div>
                        <h6 class="mb-1"><%= t.kategori %></h6>
                        <small class="text-muted"><%= new Date(t.tanggal).toLocaleDateString('id-ID', { 
                                        day: 'numeric',
                                        month: 'long',
                                        year: 'numeric'
                                    }); %>
                        </small>
                    </div>

                    <span class="text-danger fw-bold">
                        - Rp <%= t.nominal.toLocaleString('id-ID') %>
                    </span>
                </div>
                <% }); %>
            </div>
        </div>

    </div>

    <!-- BUDGET ANALYSIS -->
    <div class="report-card mt-4">

        <div class="budget-section-title">
            <i class="bi bi-pie-chart" style="font-size:24px; color:#0A5C15;"></i>
            <h5 class="fw-bold mb-0">
                Analisis Budget Anda
            </h5>
        </div>

        <!-- INCOME vs EXPENSE ANALYSIS -->
        <div class="budget-item mb-5 p-3 rounded" style="background:#f8f9fa;">
            <div class="budget-label">
                <span>
                    <i class="bi bi-graph-up text-success me-2"></i>
                    Perbandingan Pemasukan & Pengeluaran
                </span>
                <span class="budget-percentage">
                    <%= progress_pengeluaran.toFixed(1) %>%
                </span>
            </div>
            <small class="text-muted d-block mb-2">
                Rp <%= totalExpense.toLocaleString('id-ID') %> dari Rp <%= totalIncome.toLocaleString('id-ID') %>
            </small>
            <div class="progress" style="height:16px;">
                <div class="progress-bar bg-danger" style="width:<%= progress_pengeluaran %>%"></div>
            </div>
        </div>

        <!-- BUDGET ALLOCATION 50:30:20 -->
        <div style="margin-bottom:30px;">
            <h6 class="fw-bold mb-3">
                <i class="bi bi-percent"></i> Alokasi Budget <%= ratioPrimer %> : <%= ratioSekunder %> : <%= ratioTabungan %>
            </h6>

            <!-- Primer (50%) -->
            <div class="budget-item">
                <div class="budget-label">
                    <span>
                        <span class="badge bg-success"><%= ratioPrimer %>%</span>
                        Primer (Kebutuhan)
                    </span>
                    <span class="budget-percentage">
                        <%= progressPrimerPercent.toFixed(1) %>%
                    </span>
                </div>
                <small class="text-muted d-block mb-2">
                    Rp <%= used.primer.toLocaleString('id-ID') %> / Rp <%= allocation.primer.toLocaleString('id-ID') %>
                </small>
                <div class="progress">
                    <div class="progress-bar bg-success" style="width: <%= progressPrimerPercent || 0 %>%"></div>
                </div>
            </div>

            <!-- Sekunder (30%) -->
            <div class="budget-item">
                <div class="budget-label">
                    <span>
                        <span class="badge bg-warning"><%= ratioSekunder %>%</span>
                        Sekunder (Keinginan)
                    </span>
                    <span class="budget-percentage">
                        <%= progressSekunderPercent.toFixed(1) %>%
                    </span>
                </div>
                <small class="text-muted d-block mb-2">
                    Rp <%= used.sekunder.toLocaleString('id-ID') %> / Rp <%= allocation.sekunder.toLocaleString('id-ID') %>
                </small>
                <div class="progress">
                    <div class="progress-bar bg-warning" style="width: <%= progressSekunderPercent || 0 %>%"></div>
                </div>
            </div>

            <!-- Tabungan (20%) -->
            <div class="budget-item">
                <div class="budget-label">
                    <span>
                        <span class="badge bg-primary"><%= ratioTabungan %>%</span>
                        Tabungan & Investasi
                    </span>
                    <span class="budget-percentage">
                        <%= progressTabunganPercent.toFixed(1) %>%
                    </span>
                </div>
                <small class="text-muted d-block mb-2">
                    Rp <%= used.tabungan.toLocaleString('id-ID') %> / Rp <%= allocation.tabungan.toLocaleString('id-ID') %>
                </small>
                <div class="progress">
                    <div class="progress-bar bg-primary" style="width: <%= progressTabunganPercent || 0 %>%"></div>
                </div>
            </div>

        </div>

        <!-- STATUS & TIPS -->
        <div class="alert alert-info border-0 rounded" role="alert">
            <strong>
                <i class="bi bi-lightbulb me-2"></i>
                Saran untuk Anda:
            </strong>
            <ul class="mb-0 mt-2">
                <li><% if(progressPrimerPercent > 100) { %>
                    Pengeluaran Primer Anda melebihi budget yang dialokasikan. Pertimbangkan untuk mengurangi pengeluaran kebutuhan.
                <% } else { %>
                    Pengeluaran Primer Anda masih dalam batas wajar.
                <% } %></li>
                <li><% if(progressTabunganPercent < 20) { %>
                    Tabungan Anda masih kurang dari target 20%. Tingkatkan porsi tabungan Anda.
                <% } else { %>
                    Tabungan Anda sudah mencapai atau melampaui target 20%.
                <% } %></li>
            </ul>
        </div>

    </div>

</div>