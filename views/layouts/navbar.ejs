        </button>
        <!-- Menu -->
        <div class="collapse navbar-collapse" id="navbarContent">

            <ul class="navbar-nav mx-auto gap-lg-3">

                <li class="nav-item">
                    <a class="nav-link <%= currentPath === '/' ? 'active' : '' %>" href="/">
