<style>
    .navbar{
        padding:15px 0;
        background:white;
    }

    .logo-icon{
        width:40px;
        height:40px;
        background:var(--primary);
        color:white;
        border-radius:12px;
        display:flex;
        align-items:center;
        justify-content:center;
    }

    .navbar-brand{
        color:var(--primary);
        font-size:1.2rem;
    }

    .nav-link{
        font-weight:500;
        color:#666;
        transition:.3s;
        border-radius:10px;
        padding:10px 15px !important;
    }

    .nav-link:hover{
        color:var(--primary);
        background:var(--primary-light);
    }

    .nav-link.active{
        color:var(--primary) !important;
        background:var(--primary-light);
    }

    .notification-btn{
        width:45px;
        height:45px;
        border:none;
        border-radius:12px;
        background:#f5f5f5;
        font-size:18px;
    }

    .notification-btn:hover{
        background:var(--primary-light);
        color:var(--primary);
    }

    .dropdown-menu{
        border-radius:15px;
        min-width:220px;
    }

    .dropdown-item{
        padding:10px 15px;
    }

    .dropdown-item:hover{
        background:var(--primary-light);
    }

    .notification-badge {
        font-size: 11px;
        padding: 3px 6px;
        font-weight: 600;
    }

    .debt-notification-item {
        padding: 12px 15px;
        border-bottom: 1px solid #f0f0f0;
        cursor: pointer;
        transition: background 0.2s ease;
    }

    .debt-notification-item:hover {
        background: #f9f9f9;
    }

    .debt-notification-item:last-child {
        border-bottom: none;
    }

    .debt-amount {
        font-weight: 600;
        color: var(--primary);
        font-size: 14px;
    }

    .debt-due-date {
        font-size: 12px;
        color: #999;
        margin-top: 4px;
    }

    .debt-due-soon {
        color: #dc3545;
        font-weight: 500;
    }

    .debt-notification-empty {
        padding: 20px 15px;
        text-align: center;
        color: #999;
        font-size: 13px;
    }

    .btn-add-debt {
        width: 100%;
        padding: 8px 15px;
        background: var(--primary);
        color: white;
        border: none;
        border-radius: 8px;
        font-size: 13px;
        font-weight: 500;
        margin-top: 10px;
        cursor: pointer;
        transition: background 0.2s ease;
    }

    .btn-add-debt:hover {
        background: #128D24;
    }

    .modal-header {
        border-bottom: 1px solid #f0f0f0;
    }

    .modal-header h5 {
        color: var(--primary);
        font-weight: 600;
    }

    .form-label {
        font-weight: 500;
        color: #333;
        font-size: 13px;
        margin-bottom: 6px;
    }

    .form-control:focus {
        border-color: var(--primary);
        box-shadow: 0 0 0 0.2rem rgba(10, 92, 21, 0.25);
    }

</style>

<nav class="navbar navbar-expand-lg navbar-light bg-white shadow-sm sticky-top">
    <div class="container">
        <!-- Logo -->
        <a class="navbar-brand fw-bold d-flex align-items-center" href="#">
            <div class="logo-icon me-2">
                <i class="bi bi-wallet2"></i>
            </div>
            Finance Tracker
        </a>
        <!-- Toggle Mobile -->
        <button class="navbar-toggler"
                type="button"
                data-bs-toggle="collapse"
                data-bs-target="#navbarContent">
            <span class="navbar-toggler-icon"></span>
        </button>
        <!-- Menu -->
        <div class="collapse navbar-collapse" id="navbarContent">

            <ul class="navbar-nav mx-auto gap-lg-3">

                <li class="nav-item">
                    <a class="nav-link <%= currentPath === '/' ? 'active' : '' %>" href="/">
                        <i class="bi bi-house-door me-1"></i>
                        Home
                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link <%= currentPath === '/transaksi' ? 'active' : '' %>" href="/transaksi">
                        <i class="bi bi-arrow-left-right me-1"></i>
                        Transaksi
                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link <%= currentPath === '/budgeting' ? 'active' : '' %>" href="/budgeting">
                        <i class="bi bi-pie-chart me-1"></i>
                        Budgeting
                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link <%= currentPath === '/laporan' ? 'active' : '' %>" href="/laporan">
                        <i class="bi bi-file-earmark-bar-graph me-1"></i>
                        Laporan
                    </a>
                </li>

            </ul>

            <!-- Right Side -->
            <div class="d-flex align-items-center gap-3">

                <!-- Notification Hutang Dropdown -->
                <div class="dropdown">
                    <button class="btn notification-btn position-relative" type="button" data-bs-toggle="dropdown">
                        <i class="bi bi-bell"></i>
                        <% if(debtNotificationCount > 0) { %>
                            <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger notification-badge">
                                <%= debtNotificationCount %>
                            </span>
                        <% } %>
                    </button>

                    <div class="dropdown-menu dropdown-menu-end shadow border-0" style="min-width: 320px;">
                        <div style="padding: 12px 15px; border-bottom: 1px solid #f0f0f0;">
                            <h6 class="fw-bold mb-0" style="color: var(--primary);">
                                <i class="bi bi-exclamation-circle me-2"></i>
                                Pengingat Hutang
                            </h6>
                        </div>

                        <% if(notificationDebts.length > 0) { %>
                            <% notificationDebts.forEach(debt => { %>
                                <div class="debt-notification-item">
                                    <div>
                                        <div style="display: flex; justify-content: space-between; align-items: start;">
                                            <div class="debt-amount">
                                                Rp <%= Number(debt.nominal).toLocaleString('id-ID') %>
                                            </div>
                                            <form action="/debt/mark-paid/<%= debt._id %>" method="POST" style="display: inline;">
                                                <button type="submit" class="btn btn-sm btn-outline-success" style="font-size: 11px; padding: 2px 8px;">
                                                    Sudah Bayar
                                                </button>
                                            </form>
                                        </div>
                                        <p style="margin: 6px 0 0 0; font-size: 12px; color: #666;">
                                            <%= debt.deskripsi %>
                                        </p>
                                        <div class="debt-due-date">
                                            <i class="bi bi-calendar me-1"></i>
                                            <% 
                                                const dueDate = new Date(debt.tanggalJatuhTempo);
                                                const now = new Date();
                                                const daysLeft = Math.ceil((dueDate - now) / (1000 * 60 * 60 * 24));
                                            %>
                                            Jatuh tempo: <%= dueDate.toLocaleDateString('id-ID') %>
                                            <% if(daysLeft <= 1) { %>
                                                <span class="debt-due-soon"> (HARI INI!)</span>
                                            <% } else if(daysLeft <= 3) { %>
                                                <span class="debt-due-soon"> (<%= daysLeft %> hari lagi)</span>
                                            <% } %>
                                        </div>
                                    </div>
                                </div>
                            <% }); %>
                        <% } else { %>
                            <div class="debt-notification-empty">
                                <i class="bi bi-check-circle" style="font-size: 24px; color: var(--primary); display: block; margin-bottom: 8px;"></i>
                                Tidak ada hutang yang akan jatuh tempo
                            </div>
                        <% } %>

                        <button type="button" class="btn-add-debt" data-bs-toggle="modal" data-bs-target="#addDebtModal">
                            <i class="bi bi-plus-circle me-1"></i>
                            Tambah Hutang
                        </button>
                    </div>
                </div>

                <!-- Profile -->
                <div class="dropdown">

                    <a href="#"
                       class="d-flex align-items-center text-decoration-none dropdown-toggle"
                       data-bs-toggle="dropdown">

                        <% if (currentUser) { %>
                        <img src="https://ui-avatars.com/api/?name=<%= encodeURIComponent(currentUser.username) %>&background=0A5C15&color=fff"
                             width="40"
                             height="40"
                             class="rounded-circle me-2">

                        <div class="d-none d-md-block">
                            <div class="fw-semibold text-dark">
                                <%= currentUser.username %>
                            </div>
                            <small class="text-muted">
                                Personal User
                            </small>
                        </div>
                        <% } else { %>
                        <a class="nav-link btn btn-sm btn-outline-primary" href="/login">Login</a>
                        <% } %>

                    </a>

                    <ul class="dropdown-menu dropdown-menu-end shadow border-0">

                        <% if (currentUser) { %>
                        <li>
                            <a class="dropdown-item text-primary" href="/settings_profile">
                                <i class="bi bi-gear me-2"></i>
                                Settings
                            </a>
                        </li>
                        <li>
                            <a class="dropdown-item text-danger" href="/logout">
                                <i class="bi bi-box-arrow-right me-2"></i>
                                Logout
                            </a>
                        </li>
                        <% } %>

                    </ul>

                </div>

            </div>

        </div>

    </div>
</nav>

<!-- MODAL TAMBAH HUTANG -->
<div class="modal fade" id="addDebtModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">
                    <i class="bi bi-plus-circle me-2"></i>
                    Tambah Hutang Baru
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            
            <form action="/debt/add" method="POST">
                <div class="modal-body">
                    <!-- Nominal Hutang -->
                    <div class="mb-3">
                        <label class="form-label">
                            <i class="bi bi-cash-coin me-1" style="color: var(--primary);"></i>
                            Nominal Hutang
                        </label>
                        <input type="number" 
                               class="form-control form-control-lg" 
                               name="nominal" 
                               placeholder="Rp 0" 
                               required 
                               min="0"
                               step="1000">
                        <small class="text-muted">Masukkan jumlah hutang dalam Rupiah</small>
                    </div>

                    <!-- Deskripsi -->
                    <div class="mb-3">
                        <label class="form-label">
                            <i class="bi bi-file-text me-1" style="color: var(--primary);"></i>
                            Deskripsi (Opsional)
                        </label>
                        <input type="text" 
                               class="form-control" 
                               name="deskripsi" 
                               placeholder="Contoh: Hutang ke Teman, Cicilan Motor, dll"
                               value="Hutang">
                        <small class="text-muted">Jelaskan tujuan atau sumber hutang</small>
                    </div>

                    <!-- Tanggal Jatuh Tempo -->
                    <div class="mb-3">
                        <label class="form-label">
                            <i class="bi bi-calendar-event me-1" style="color: var(--primary);"></i>
                            Tanggal Jatuh Tempo
                        </label>
                        <input type="date" 
                               class="form-control form-control-lg" 
                               name="tanggalJatuhTempo" 
                               required>
                        <small class="text-muted">Pilih tanggal janji bayar</small>
                    </div>

                    <!-- Info -->
                    <div class="alert alert-info border-0 rounded" style="background: rgba(10, 92, 21, 0.1); border-left: 3px solid var(--primary);">
                        <small>
                            <i class="bi bi-info-circle me-1"></i>
                            Anda akan menerima notifikasi ketika hutang akan jatuh tempo dalam 3 hari ke depan
                        </small>
                    </div>
                </div>

                <div class="modal-footer border-top">
                    <button type="button" class="btn btn-light" data-bs-dismiss="modal">
                        Batal
                    </button>
                    <button type="submit" class="btn btn-primary" style="background: var(--primary); border: none;">
                        <i class="bi bi-check-circle me-2"></i>
                        Simpan Hutang
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>