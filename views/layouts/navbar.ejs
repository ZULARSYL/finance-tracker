<style>
    .navbar{
        padding:15px 0;
        background:white;
    }

    .logo-icon{
        width:40px;
        height:40px;
        background:var(--primary);
        color:white;
        border-radius:12px;
        display:flex;
        align-items:center;
        justify-content:center;
    }

    .navbar-brand{
        color:var(--primary);
        font-size:1.2rem;
    }

    .nav-link{
        font-weight:500;
        color:#666;
        transition:.3s;
        border-radius:10px;
        padding:10px 15px !important;
    }

    .nav-link:hover{
        color:var(--primary);
        background:var(--primary-light);
    }

    .nav-link.active{
        color:var(--primary) !important;
        background:var(--primary-light);
    }

    .notification-btn{
        width:45px;
        height:45px;
        border:none;
        border-radius:12px;
        background:#f5f5f5;
        font-size:18px;
    }

    .notification-btn:hover{
        background:var(--primary-light);
        color:var(--primary);
    }

    .dropdown-menu{
        border-radius:15px;
        min-width:220px;
    }

    .dropdown-item{
        padding:10px 15px;
    }

    .dropdown-item:hover{
        background:var(--primary-light);
    }
</style>

<nav class="navbar navbar-expand-lg navbar-light bg-white shadow-sm sticky-top">
    <div class="container">
        <!-- Logo -->
        <a class="navbar-brand fw-bold d-flex align-items-center" href="#">
