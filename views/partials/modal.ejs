<!-- modal input transaksi pemasukan -->
<div class="modal fade" id="incomeModal">
    <div class="modal-dialog modal-lg">
        <div class="modal-content border-0 rounded-4">
            <div class="modal-header">
                <h5 class="modal-title">
                    Tambah Pemasukan
                </h5>
                <button
                    class="btn-close"
                    data-bs-dismiss="modal">
                </button>
            </div>
            <div class="modal-body">
                <form action="/transaksi/pemasukan" method="POST" id="incomeForm">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">
                                Jenis Pemasukan
                            </label>
                            <select class="form-select" name="kategori">
                                <option value="Gaji">Gaji</option>
                                <option value="Lembur">Lembur</option>
                                <option value="Tambahan">Tambahan</option>
                            </select>
                            <input type="hidden" name="jenis" value="Pemasukan">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">
                                Nominal
                            </label>
                            <input
                                id="nominal"
                                type="text"
                                class="form-control"
                                maxlength="20">
                            <input
                                type="hidden"
                                id="nominal-raw"
                                name="nominal"
                                maxlength="15">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">
                                Tanggal
                            </label>
                            <input
                                type="date"
                                class="form-control"
                                name="tanggal">
                        </div>
                        <div class="col-md-12">
                            <label class="form-label">
                                Catatan
                            </label>
                            <textarea
                                class="form-control"
                                name="catatan"
                                rows="3"></textarea>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button
                            class="btn btn-outline-secondary"
                            data-bs-dismiss="modal">
                            Batal
                        </button>
                        <button class="btn btn-income" type="submit">
                            Simpan
                        </button>
                    </div>
                </form>
            </div>

        </div>
    </div>
</div>

